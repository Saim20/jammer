rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────

    // Is the incoming request from a signed-in user?
    function isAuthed() {
      return request.auth != null;
    }

    // Is the caller an admin? (presence of their UID doc in the admins collection)
    function isAdmin() {
      return isAuthed() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Does the incoming document's userId field match the caller's UID?
    function isOwner() {
      return request.resource.data.userId == request.auth.uid;
    }

    // Validate leaderboard entry shape on create:
    //   • All required fields are present
    //   • userId matches the caller (no spoofing other players)
    //   • score is a non-negative integer
    //   • userName is a non-empty string  ≤ 100 chars
    //   • userPhoto is a string (may be empty)
    //   • timestamp is a server timestamp (set via serverTimestamp())
    function validLeaderboardEntry() {
      let d = request.resource.data;
      return d.keys().hasAll(['userId', 'userName', 'userPhoto', 'score', 'timestamp'])
          && d.userId   is string
          && d.userId   == request.auth.uid
          && d.userName is string
          && d.userName.size() > 0
          && d.userName.size() <= 100
          && d.userPhoto is string
          && d.score    is int
          && d.score    >= 0
          && d.timestamp == request.time;
    }

    // ── admins collection ──────────────────────────────────────────────────────
    // Presence of a document (UID as ID) grants admin rights.
    // Admins can read their own entry. Nobody writes from the client.
    // Add/remove admins directly via Firebase Console or Admin SDK.
    match /admins/{userId} {
      allow read:  if isAuthed() && request.auth.uid == userId;
      allow write: if false;
    }

    // ── config collection ──────────────────────────────────────────────────────
    // Stores game-wide settings (e.g. config/game).
    // All authenticated players may read (game page needs these values).
    // Only admins may write.
    match /config/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── words collection ───────────────────────────────────────────────────────
    // Authenticated players may read. Admins may create, update, and delete.
    match /words/{wordId} {
      allow read:   if isAuthed();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── leaderboard collection ─────────────────────────────────────────────────
    // Authenticated players may read all entries (for the top-10 view).
    // A player may only CREATE a new entry on their own behalf with valid data.
    // Nobody may update or delete entries from the client — scores are immutable.
    match /leaderboard/{entryId} {
      allow read:   if isAuthed();
      allow create: if isAuthed() && isOwner() && validLeaderboardEntry();
      allow update: if false;
      allow delete: if false;
    }

    // ── Catch-all: deny everything else ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
