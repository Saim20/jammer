{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun dev",
      "cwd": "${workspaceFolder}",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true
    },
    {
      "name": "Next.js: debug client-side (Firefox)",
      "type": "firefox",
      "request": "launch",
      "reAttach": true,
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "profile": "default-release",
      "pathMappings": [
        {
          "url": "file:///home/saim/Documents/Dev/tathirmichil/",
          "path": "${workspaceFolder}/"
        }
      ],
      "skipFiles": [
        "node_modules/**",
        "<node_internals>/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Next.js: debug full stack (Firefox)",
      "configurations": [
        "Next.js: debug server-side",
        "Next.js: debug client-side (Firefox)"
      ],
      "stopAll": true
    }
  ]
}